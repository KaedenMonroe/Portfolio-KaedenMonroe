---
import BaseLayout from '../layouts/BaseLayout.astro';
import GridRailShell from '../components/GridRailShell.astro';
import NavBar from '../components/NavBar.astro';
import SectionBlock from '../components/SectionBlock.astro';
import LedgerRow from '../components/LedgerRow.astro';
import ControlLoopDiagram from '../components/ControlLoopDiagram.astro';
import Footer from '../components/Footer.astro';
import { getProfile, getProjects, getSkillCategories } from '../lib/content';

const profile = await getProfile();
const projects = await getProjects();
const skillCategories = getSkillCategories();

const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Skills', href: '#skills' },
  { label: 'Projects', href: '#projects' },
  ...(profile.blogUrl ? [{ label: 'Blog', href: profile.blogUrl, external: true }] : []),
  { label: 'Résumé', href: profile.resumeUrl, external: true, cta: true },
];
---

<BaseLayout title={`${profile.name} — ${profile.role}`} description={profile.heroSubtext}>
  <GridRailShell>
    <NavBar name={profile.name} links={navLinks} />
    <main id="main-content">
      <div id="hero" class="hero">
        <div class="hero__grid">
          <SectionBlock eyebrow={profile.role}>
            <h1 class="hero__headline">{profile.heroHeadline}</h1>
            <p>{profile.heroSubtext}</p>
          </SectionBlock>
          <div class="hero__diagram">
            <ControlLoopDiagram />
          </div>
        </div>
        <div class="hero__meta">
          <span class="hero__meta-label">FIG. 01 — CONTROL LOOP, GROUND TEST (sample log)</span>
          <dl class="hero__telemetry">
            <div>
              <dt>IMU</dt>
              <dd>199.8 Hz</dd>
            </div>
            <div>
              <dt>GAIN MARGIN</dt>
              <dd>6.4 dB</dd>
            </div>
            <div>
              <dt>BATT</dt>
              <dd>15.8 V</dd>
            </div>
          </dl>
        </div>
      </div>
      <div class="about-skills-row">
        <SectionBlock id="about" eyebrow="ABOUT">
          <profile.Content />
        </SectionBlock>
        <SectionBlock id="skills" eyebrow="SKILLS">
          {
            skillCategories.map((category) => (
              <div class="skills-group">
                {category.tags.map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            ))
          }
        </SectionBlock>
      </div>
      <SectionBlock id="projects" eyebrow="PROJECTS" />
      {
        projects.map((project) => (
          <LedgerRow
            tag={project.tag}
            title={project.title}
            subtitle={project.subtitle}
            detail={project.detail}
            image={project.image}
          />
        ))
      }
    </main>
    <Footer
      copyrightName={profile.copyrightName}
      email={profile.email}
      linkedinUrl={profile.linkedinUrl}
      githubUrl={profile.githubUrl}
      blogUrl={profile.blogUrl}
    />
  </GridRailShell>
</BaseLayout>

<style>
  .hero {
    border-block-end: var(--border-width) solid var(--border);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-block-end: var(--border-width) solid var(--border-faint);
  }

  .hero__grid :global(.section-block) {
    border-inline-end: var(--border-width) solid var(--border-faint);
  }

  .hero__diagram {
    padding: var(--space-20) var(--space-40);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__headline {
    margin: 0 0 var(--space-16);
    max-width: 20ch;
    font: 600 var(--text-3xl) / 1.15 var(--font-sans);
    color: var(--ink);
  }

  .hero__meta {
    padding: var(--space-10) var(--space-44) var(--space-14);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-10);
  }

  .hero__meta-label {
    font: 500 var(--text-2xs) var(--font-mono);
    color: var(--ink-muted);
  }

  .hero__telemetry {
    margin: 0;
    display: flex;
    gap: var(--space-22);
    font: 500 var(--text-xs) var(--font-mono);
    color: var(--ink-muted);
  }

  .hero__telemetry div {
    display: flex;
    gap: var(--space-8);
  }

  .hero__telemetry dt::after {
    content: ':';
  }

  .hero__telemetry dd {
    margin: 0;
  }

  .about-skills-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-block-end: var(--border-width) solid var(--border);
  }

  .about-skills-row :global(.section-block:first-child) {
    border-inline-end: var(--border-width) solid var(--border);
  }

  .skills-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }

  /* Tablet mirrors --bp-tablet (768px), see tokens.css: the hero and the
     about/skills row drop from two columns to one, and their dividing
     hairline border moves with them. */
  @media (max-width: 768px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero__grid :global(.section-block) {
      border-inline-end: none;
    }

    .hero__meta {
      padding: var(--space-10) var(--space-28) var(--space-14);
    }

    .about-skills-row {
      grid-template-columns: 1fr;
    }

    .about-skills-row :global(.section-block:first-child) {
      border-inline-end: none;
      border-block-end: var(--border-width) solid var(--border);
    }
  }

  /* Mobile mirrors --bp-mobile (480px), see tokens.css: the headline steps
     down a size so it doesn't wrap into a wall of text on a narrow phone. */
  @media (max-width: 480px) {
    .hero__headline {
      font-size: var(--text-2xl);
    }

    .hero__meta {
      padding: var(--space-10) var(--space-16) var(--space-14);
    }
  }
</style>

<style is:global>
  .section-block__content p {
    margin: 0;
    max-width: 60ch;
    font: 400 var(--text-lg) / 1.65 var(--font-sans);
    color: var(--ink-body);
  }
</style>
