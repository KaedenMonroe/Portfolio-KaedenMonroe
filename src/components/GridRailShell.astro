---
const railMarks = ['01', '02', '03', '04', '05'];
---

<div class="grid-rail-shell">
  <aside class="grid-rail-shell__rail" aria-hidden="true">
    {railMarks.map((mark) => <span>{mark}</span>)}
  </aside>
  <div class="grid-rail-shell__content">
    <slot />
  </div>
</div>

<style>
  .grid-rail-shell {
    display: grid;
    grid-template-columns: var(--rail-width) 1fr;
    min-height: 100vh;
    max-width: var(--container-max);
    margin-inline: auto;
    border-inline: var(--border-width) solid var(--border);
  }

  .grid-rail-shell__rail {
    border-inline-end: var(--border-width) solid var(--border);
    background: var(--rail-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block-start: var(--space-22);
    gap: 140px;
    font: 500 var(--text-2xs) var(--font-mono);
    color: var(--ink-faint);
    position: sticky;
    top: 0;
    height: 100vh;
  }

  .grid-rail-shell__content {
    min-width: 0;
  }

  @media (max-width: 768px) {
    .grid-rail-shell {
      grid-template-columns: 1fr;
    }

    .grid-rail-shell__rail {
      display: none;
    }
  }
</style>
