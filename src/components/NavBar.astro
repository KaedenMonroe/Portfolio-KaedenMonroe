---
interface NavLink {
  label: string;
  href: string;
  external?: boolean;
  /** Highlights the link as the primary call to action (e.g. Résumé). */
  cta?: boolean;
}

interface Props {
  name: string;
  links: NavLink[];
}

const { name, links } = Astro.props;
---

<header class="nav-bar">
  <span class="nav-bar__name">{name}</span>
  <details class="nav-bar__menu">
    <summary class="nav-bar__menu-toggle">
      <span class="nav-bar__menu-toggle-label nav-bar__menu-toggle-label--closed">MENU +</span>
      <span class="nav-bar__menu-toggle-label nav-bar__menu-toggle-label--open">CLOSE −</span>
    </summary>
    <nav class="nav-bar__links" aria-label="Primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={['nav-bar__link', { 'nav-bar__link--cta': link.cta }]}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
            {link.external ? ' ↗' : ''}
            {link.cta ? ' ↓' : ''}
          </a>
        ))
      }
    </nav>
  </details>
</header>

<style>
  .nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    padding: var(--space-20) var(--space-40);
    border-block-end: var(--border-width) solid var(--border);
    position: sticky;
    top: 0;
    background: var(--paper);
    z-index: 10;
  }

  .nav-bar__name {
    font: 600 var(--text-xl) var(--font-sans);
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  /* Desktop: the <details> wrapper dissolves into the nav bar's flex row,
     and the links stay visible regardless of the native [open] state
     (this plain rule beats the browser's default hidden-until-open style,
     since author rules win over user agent ones); the toggle stays hidden
     since there's nothing to toggle. */
  .nav-bar__menu {
    display: contents;
  }

  .nav-bar__menu-toggle {
    display: none;
  }

  .nav-bar__links {
    display: flex;
    gap: var(--space-28);
    font: 500 var(--text-sm) var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    /* AC-7: groups the section links so supporting browsers highlight
       the current one via :target-current, with no JavaScript. */
    scroll-target-group: auto;
  }

  .nav-bar__link {
    color: var(--ink-muted);
    transition: color 120ms ease;
  }

  .nav-bar__link:hover {
    color: var(--accent-hover);
  }

  .nav-bar__link--cta {
    color: var(--accent);
  }

  .nav-bar__link:target-current {
    color: var(--accent);
  }

  /* Tablet and mobile mirror --bp-tablet (768px), see tokens.css. */
  @media (max-width: 768px) {
    .nav-bar__menu {
      display: block;
      width: 100%;
    }

    .nav-bar__menu-toggle {
      display: flex;
      justify-content: flex-end;
      list-style: none;
      cursor: pointer;
      font: 500 var(--text-sm) var(--font-mono);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .nav-bar__menu-toggle::-webkit-details-marker {
      display: none;
    }

    .nav-bar__menu-toggle-label--open {
      display: none;
    }

    .nav-bar__menu[open] .nav-bar__menu-toggle-label--closed {
      display: none;
    }

    .nav-bar__menu[open] .nav-bar__menu-toggle-label--open {
      display: inline;
    }

    .nav-bar__links {
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-14);
      padding-block-start: var(--space-16);
    }

    .nav-bar__menu[open] .nav-bar__links {
      display: flex;
    }
  }
</style>
